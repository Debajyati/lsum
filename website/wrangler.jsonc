{
	"compatibility_date": "2026-04-17",
	"compatibility_flags": [
		"global_fetch_strictly_public"
	],
	"name": "lsum-website",
	"assets": {
		"directory": "./dist",
		"binding": "STATIC_ASSETS"
	},
  "routes": [
    {
      "pattern": "lsum.debajyati.com",
      "custom_domain": true
    }
  ],
  "observability": {
		"enabled": true
	}
}
