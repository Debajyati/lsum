---
---

<div class="w-full max-w-4xl mx-auto rounded-xl overflow-hidden border border-slate-800 bg-slate-900 shadow-2xl shadow-cyan-900/10">
  <!-- Terminal Header -->
  <div class="bg-slate-800 px-4 py-2 flex items-center justify-between border-b border-slate-700">
    <div class="flex space-x-2">
      <div class="w-3 h-3 rounded-full bg-red-500/80"></div>
      <div class="w-3 h-3 rounded-full bg-yellow-500/80"></div>
      <div class="w-3 h-3 rounded-full bg-green-500/80"></div>
    </div>
    <div class="text-xs font-mono text-slate-400">lsum — bash — 80x24</div>
    <div class="w-12"></div>
  </div>

  <!-- Terminal Body -->
  <div class="p-6 font-mono text-sm leading-relaxed overflow-x-auto whitespace-nowrap">
    <div class="mb-4 flex items-center space-x-2">
      <span class="text-green-400">➜</span>
      <span class="text-cyan-400">~</span>
      <span class="text-slate-100">lsum -g</span>
    </div>

    <div class="flex flex-wrap gap-6">
      <!-- Image Group -->
      <div class="inline-block p-4 border border-green-500/40 rounded bg-green-500/5 min-w-50">
        <div class="text-green-400 font-bold mb-2 flex items-center gap-2">
          🖼️ image/jpeg (3)
        </div>
        <div class="text-green-300">
          <div>beach.jpg</div>
          <div>mountains.jpg</div>
          <div>avatar.jpg</div>
        </div>
      </div>

      <!-- Document Group -->
      <div class="inline-block p-4 border border-blue-500/40 rounded bg-blue-500/5 min-w-50">
        <div class="text-blue-400 font-bold mb-2 flex items-center gap-2">
          📄 text/plain (2)
        </div>
        <div class="text-blue-300">
          <div>README.md</div>
          <div>TODO.txt</div>
        </div>
      </div>

      <!-- Data Group -->
      <div class="inline-block p-4 border border-yellow-500/40 rounded bg-yellow-500/5 min-w-50">
        <div class="text-yellow-400 font-bold mb-2 flex items-center gap-2">
          🔧 application/json (1)
        </div>
        <div class="text-yellow-300">
          <div>config.json</div>
        </div>
      </div>

      <!-- Python Group -->
      <div class="inline-block p-4 border border-cyan-500/40 rounded bg-cyan-500/5 min-w-50">
        <div class="text-cyan-400 font-bold mb-2 flex items-center gap-2">
          🐍 text/x-script.python (2)
        </div>
        <div class="text-cyan-300">
          <div>main.py</div>
          <div>deploy.py</div>
        </div>
      </div>
    </div>

    <div class="mt-6 animate-pulse w-2 h-5 bg-slate-400"></div>
  </div>
</div>
